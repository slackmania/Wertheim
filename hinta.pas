implementation


function Encode64(S: utf8string): string;
var
  i: Integer;
  a: Integer;
  x: Integer;
  b: Integer;
begin
  Result := '';
  a := 0;
  b := 0;
  for i := 1 to Length(s) do
  begin
    x := Ord(s[i]);
    b := b * 256 + x;
    a := a + 8;
    while a >= 6 do
    begin
      a := a - 6;
      x := b div (1 shl a);
      b := b mod (1 shl a);
      Result := Result + Codes64[x + 1];
    end;
  end;
  if a > 0 then
  begin
    x := b shl (6 - a);
    Result := Result + Codes64[x + 1];
  end;
end;

function Decode64(S: utf8string): string;
var
  i: Integer;
  a: Integer;
  x: Integer;
  b: Integer;
begin
  Result := '';
  a := 0;
  b := 0;
  for i := 1 to Length(s) do
  begin
    x := Pos(s[i], codes64) - 1;
    if x >= 0 then
    begin
      b := b * 64 + x;
      a := a + 6;
      if a >= 8 then
      begin
        a := a - 8;
        x := b shr a;
        b := b mod (1 shl a);
        x := x mod 256;
        Result := Result + chr(x);
      end;
    end
    else
      Exit;
  end;
end;

function BitmapToBase64(ABitmap: TBitmap): string;
var
SS: TStringStream;
V: utf8string;
begin
SS := TStringStream.Create('');
try
ABitmap.SaveToStream(SS);
V := SS.DataString;
Result := Encode64(V); // from NativeXml
finally
SS.Free;
end;
end;

function Base64ToBitmap(const S: string): TBitmap;
var
SS: TStringStream;
V: utf8string;
begin
V := Decode64(S);
SS := TStringStream.Create(V);
try
Result := TBitmap.Create;
Result.LoadFromStream(SS);
finally
SS.Free;
end;
end;



function bekod(mit:utf8string) : utf8string;
var
  h,x            : integer;
  q,w,q1         : utf8string;
  q0,i,kq,z, dv  : integer;
begin
    //dv:= pwdhossz div 2;
    dv:= pwdhossz;
    for z:=1 to 2 do begin
 //    for z:=1 to dv+1 do begin  // :)
       x:= utf8length(mit); // a kódolandó szöveg hossza
        h:=1;
        w:='';
        for q0:=1 to x do begin
          //kq:=kod[h];
          q:=hintar[h]; // az aktuális kódsor
            q1:=utf8copy(mit,q0,1);
            i:=utf8pos(q1,abc0);  // q -> abc0
            q1:=utf8copy(q,i,1);
            w:=w+q1 ;
             if h<pwdhossz then h:=h+1 else h:=1;
            end;
        mit:=w;
    end;
   // end;
    bekod:=encode64(w);
end;

function kikod(mit:utf8string) : utf8string;
var
  h,x      : integer;
  q,w,q1   : utf8string;
  q0,i,z   : integer;
  dv : integer;
begin
     //dv:= pwdhossz div 2;
     dv:= pwdhossz;
     mit:=decode64(mit);
     for z:=1 to 2 do begin

 //    for z:=1 to dv+1 do begin
       x:= utf8length(mit); // a kódolandó szöveg hossza
        h:=1;
        w:='';
        for q0:=1 to x do begin
            q:=hintar[h];
             q1:=utf8copy(mit,q0,1);

             i:=utf8pos(q1,q);
             q1:=utf8copy(abc0,i,1); // q->abc0


             w:=w+q1 ;
             if h<pwdhossz then h:=h+1 else h:=1;
        end;

        mit:=w;

  //   end;

end;
  kikod:=w;
end;


function enkod(f : string) : string;

begin
    result:=f;
        result:=encode64(f);
end;


function a_keres(c : utf8string) : integer;
begin
     a_keres:=utf8pos(c,abc0) // ez a sorszáma
end;


procedure pw_to_kod(mit : utf8string);
var
          t            : integer;
          l            : integer;
          c            : utf8string;
          wossz        : longint;
begin
  // a bejövő kódolatlan jelszóból megcsinálom a kódoló szekvenciát
  // a kerekterek  mindegyike meghatározza a kódolás lépcsőfokain, hogy
  // melyik sorral kódolom el az előzőt.
  // A karakterek NEM ASCII, hanem az 'abc0' tömbben fellelhető sorszámuk
  // alapján történik.
  //---------------------------------------
  //
  wossz:=0;
  for t:=1 to 50 do kod[t]:=0;
  l:= utf8length(mit); // ennyi elemmel kell foglalkozni
  for t:=1 to l do begin
      c:=utf8copy(mit,t,1);
      kod[t]:=utf8pos(c,abc0);
      wossz:=wossz+ord(kod[t]);
     // kod[t]:=a_keres(c);
  end;
  pwdcode:= ( wossz -((wossz div l ) div 10));
  pwdhossz:=l;
end;


procedure genhinta(pwd : string);
{
 Tehát az eljárás a következő:
 Két dolgot kell figyelmbe venni:
 1 - A jelszó karakterei
 2 - A kulcs-szám sorozat
 ( tarr[x,y] )
 A jelszó karaktereit a kulcsok y sorainak kiválasztására használom
 A kulcs-számból készítem a 64x64 tömb x sorait.
 Ha az x elemet meghatározó kulcs-szám rövidebb, mint a jelszó, akkor újra indul az elejétől...
 PL.
 Jelszó: prutty
 kulcs-szám: 132
 Generáláskor a NAGY táblázatból kiveszem az 1,3 és 2 indexű sorokat [1,...], [2,...] stb
 A jelszóból pedig azt generálom le, hogy ezeken belül MELYIK sorok lesznek használva...
}
var l,t : integer;
begin
  pwd:=encode64(pwd);
  pw_to_kod(trim(pwd));
  l:= pwdhossz;
    for t:=1 to l do begin
     // hinta[t]:=tarr[
      hintar[t]:=tarr[kod[t],ord(pwd[t])];
    end;
end;

{
 MINDENKÉPPEN A BASE64 karakterkészletével kell dolgozni, ezáltal
 a jelszót is arra kell kódolni!



 }

 function kikodol(mit, jelszo : utf8string) : utf8string;
 var t1,t2,t3  : utf8string;
 begin
   //Kikódolás
   genhinta(jelszo);

    t1:=mit;

    t2:=kikod(t1);
    t3:=decode64(t2);

    t1:=kisecure(t3,jelszo);


    kikodol:=t1;

 end;

function bekodol(mit, jelszo : utf8string) : utf8string;
var
    t2, t1,t3 : utf8string;
begin
  // kódolás
  genhinta(jelszo);

  t1:=mit;

  t1:=besecure(mit,jelszo);
  t2:=encode64(t1);

  t3:=bekod(t2);

  bekodol:=t3;
end;


function hintabe(mit, jelszo : utf8string) : utf8string;
begin
     hintabe:=bekodol(mit, jelszo);
end;

function hintaki(mit, jelszo : utf8string) : utf8string;
begin
     hintaki:=kikodol(mit, jelszo);
end;

